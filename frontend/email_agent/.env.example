# Email Agent Configuration
# Copy this file to .env and fill in your credentials

# Backend API URL
VITE_API_URL=http://localhost:3001

# Optional: Pre-fill default email (leave empty for user input)
# VITE_DEFAULT_EMAIL=your-email@gmail.com

# Optional: Pre-fill default OpenAI API key (leave empty for user input)
# VITE_DEFAULT_OPENAI_API_KEY=sk-proj-your-key-here
